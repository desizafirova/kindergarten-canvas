generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime
  role      Role     @default(ADMIN)
  id        Int      @id @default(autoincrement())
}

model news_items {
  id          Int        @id @default(autoincrement())
  title       String
  content     String
  imageUrl    String?
  status      NewsStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime

  @@index([status])
}

model teachers {
  id           Int           @id @default(autoincrement())
  firstName    String
  lastName     String
  position     String
  bio          String?
  photoUrl     String?
  status       TeacherStatus @default(DRAFT)
  displayOrder Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime

  @@index([status, displayOrder])
}

enum NewsStatus {
  DRAFT
  PUBLISHED
}

enum Role {
  ADMIN
  DEVELOPER
}

enum TeacherStatus {
  DRAFT
  PUBLISHED
}

enum EventStatus {
  DRAFT
  PUBLISHED
}

enum DeadlineStatus {
  DRAFT
  PUBLISHED
}

model Event {
  id           Int         @id @default(autoincrement())
  title        String
  description  String?
  eventDate    DateTime    @map("event_date") @db.Timestamptz(6)
  eventEndDate DateTime?   @map("event_end_date") @db.Timestamptz(6)
  location     String?
  isImportant  Boolean     @default(false) @map("is_important")
  imageUrl     String?     @map("image_url")
  status       EventStatus @default(DRAFT)
  publishedAt  DateTime?   @map("published_at") @db.Timestamptz(6)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, eventDate])
  @@index([status, createdAt])
  @@map("events")
}

model Deadline {
  id           Int            @id @default(autoincrement())
  title        String
  description  String?
  deadlineDate DateTime       @map("deadline_date") @db.Timestamptz(6)
  isUrgent     Boolean        @default(false) @map("is_urgent")
  status       DeadlineStatus @default(DRAFT)
  publishedAt  DateTime?      @map("published_at") @db.Timestamptz(6)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, deadlineDate])
  @@index([status, createdAt])
  @@map("deadlines")
}
