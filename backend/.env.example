# ===========================================
# Kindergarten Canvas Backend - Environment Variables
# ===========================================
# Copy this file to .env and update values

# GLOBAL APP CONFIG
APP_URL_HOST='localhost'
APP_URL_PORT='3344'
NODE_ENV='development'  # development | staging | production

# SSL (production only)
SSL_ALLOW='false'
SSL_PRIVATE_KEY='/etc/letsencrypt/live/mydomain/privkey.pem'
SSL_CERTIFICATE='/etc/letsencrypt/live/mydomain/cert.pem'

# API
API_PREFIX='api'
API_VERSION='v1'
API_JSON_LIMIT='5mb'
API_EXT_URLENCODED='false'

# CORS - Frontend URL for allowed origins
# In production, set this to your Vercel frontend URL
CORS_ALLOW_ORIGIN='http://localhost:5173'
FRONTEND_URL='http://localhost:5173'

# JWT - CHANGE THESE IN PRODUCTION!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET_USER='your-user-secret-key-min-64-characters-change-in-production'
JWT_SECRET_ADMIN='your-admin-secret-key-min-64-characters-change-in-production'
JWT_SECRET_APP='your-app-secret-key-min-64-characters-change-in-production'
JWT_EXPIRED_IN='1h'
JWT_REFRESH_EXPIRATION='7d'

# BCRYPT - Minimum 12 rounds for security (NFR-S1)
BCRYPT_SALTROUNDS='12'

# DEFAULT ADMIN USER - Used by seed script (npx prisma db seed)
# CHANGE THESE IN PRODUCTION!
DEFAULT_ADMIN_EMAIL='admin@kindergarten.bg'
DEFAULT_ADMIN_PASSWORD='your-secure-password-here'

# RATE LIMIT - 100 requests per 1 minute per IP (NFR-S7)
RATE_LIMIT_MAX='100'
RATE_LIMIT_WINDOW='1'

# DEBUG
DEBUG_HTTP_REQUEST='true'
DEBUG_HTTP_CONNECTION='false'

# DATABASE - PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# NOTE: Docker Compose uses port 5433 to avoid conflicts with local PostgreSQL (5432)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/kindergarten_canvas?schema=public"

# EMAIL - Nodemailer / Google OAuth2 (used by job application emails - Stories 6.7, 6.8)
EMAIL_USER=''
EMAIL_PASSWORD=''
EMAIL_SERVICE=''
EMAIL_OAUTH_CLIENT_ID=''
EMAIL_OAUTH_CLIENT_SECRET=''
EMAIL_OAUTH_REFRESH_TOKEN=''
EMAIL_OAUTH_REDIRECT=''

# EMAIL - AWS SES (Epic 8: Email Notification System)
# Get these from your AWS IAM console (create a user with SES send permissions)
# AWS region where your SES identity is verified (e.g. eu-central-1, us-east-1)
AWS_SES_REGION='eu-central-1'
# IAM user credentials with ses:SendEmail permission
AWS_SES_ACCESS_KEY_ID='your-aws-access-key-id'
AWS_SES_SECRET_ACCESS_KEY='your-aws-secret-access-key'
# The FROM address — must be a verified identity in SES
AWS_SES_FROM_EMAIL='noreply@your-kindergarten-domain.bg'

# KINDERGARTEN_NAME - Used in confirmation email subject and body (Story 6.8)
# Customize to your kindergarten's name; defaults to 'Детска Градина' if empty
KINDERGARTEN_NAME=''

# CLOUDINARY - Image storage (Story 3.3)
# Get these from your Cloudinary dashboard: https://cloudinary.com/console
# Free tier: 10GB storage, 300K images, 20GB bandwidth
CLOUDINARY_CLOUD_NAME='your-cloud-name'
CLOUDINARY_API_KEY='your-api-key'
CLOUDINARY_API_SECRET='your-api-secret'
